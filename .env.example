# Drizzle
# Replace with your DB credentials!
DATABASE_URL="libsql://db-name-user.turso.io"
# A local DB can also be used in dev as well
# DATABASE_URL="file:local.db"
DATABASE_AUTH_TOKEN=""

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# AI Therapist + Risk Intelligence
GOOGLE_GENERATIVE_AI_API_KEY=""
AI_TEXT_MODEL="gemini-2.5-flash"
AI_RISK_MODEL="gemini-2.5-flash"
AI_LIVE_MODEL="gemini-2.5-flash-native-audio-preview-12-2025"
AI_LIVE_MODEL_FALLBACKS="gemini-2.5-flash-native-audio-preview-12-2025,gemini-2.0-flash-live-001"
AI_CHAT_ENABLED="true"
AI_LIVE_VOICE_ENABLED="true"
AI_HISTORY_INGEST_ENABLED="true"
AI_DEIDENTIFY_MODE="true"
AI_MAX_MESSAGE_CHARS="2000"
MAX_HISTORY_UPLOAD_BYTES="26214400"

# S3 / MinIO (S3-compatible) history file storage
S3_ENDPOINT="http://127.0.0.1:9000"
S3_REGION="us-east-1"
S3_BUCKET="recovery-track-history"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

# Optional secret for /api/internal/jobs/process
INTERNAL_CRON_SECRET=""
